#! /usr/bin/perl

use Tk;

@features;
@testCases;
@mapping;
$numberOfTestCases;
$numberOfFeatures;
$currentSelectionFeature = '';
$profileType = "pro";

$main = MainWindow->new();
$main->title("ReconCalc Control File Creator.");


# ---------------------
# Set up the menu
# ---------------------
$menuBarArea = $main->Frame();

# --- File Menu ---
$fileMenuItem = $menuBarArea->Menubutton(-text => 'File',
				  -borderwidth => 2
				  )->pack(-side => 'left',
					  -padx => 2
					  );

# File Open Menu Item
#$fileMenuItem->command('-label' => 'Open project',
#		       -command => [\&OpenRecon]
#		       );
# File Save Menu Item
$fileMenuItem->command('-label' => 'Create and save control file.',
		       -command => [\&SaveRecon]
		       );
# Close Menu Item
$fileMenuItem->command('-label' => 'Exit',
		       -command => [\&ExitRecon]
		       );



# --- Configure Menu ---
$configureMenuItem = $menuBarArea->Menubutton(-text => 'Configure',
				  -borderwidth => 2
					      )->pack(-side => 'left',
						      -padx => 2
						      );

# Set output dir menu item
$configureMenuItem->command('-label' => 'Set profile type as Generic Profiling Format',
		       -command => [\&SetProfileTypeToPRO]
		       );
$configureMenuItem->command('-label' => 'Set profile type as Progress Profiling Format',
		       -command => [\&SetProfileTypeToPPF]
		       );

# Set pdf viewer menu item
#$configureMenuItem->command('-label' => 'Set PDF Viewer',
#		       -command => [\&OpenRecon]
#			    );



# --- Help Menu ---
$helpMenuItem = $menuBarArea->Menubutton(-text => 'Help',
				  -borderwidth => 2
				  )->pack(-side => 'left',
					  -padx => 2
					  );


# About ReconCalc menu item
#$helpMenuItem->command('-label' => 'User Guide',
#		       -command => [\&OpenRecon]
#			    );


# User guide menu item 
$helpMenuItem->command('-label' => 'About ReconCalc',
		       -command => [\&DisplayAbout]
			    );


# ----------------
#  Set up main UI
# ----------------

# 'Add Feature' Widgets.  A button and a text box.
$addFeatureButtonArea = $main->Button(-text => 'Add Feature');
$addFeatureButtonArea->configure(-command => [\&AddFeature]);

$addFeatureTextBoxArea = $main->Entry(-textvariable => \$featureName);
$addFeatureTextBoxArea->focus;
$featureName = "Enter Feature Name";

# 'Add Test Case' Button.

$addTestCaseButtonArea = $main->Button(-text => 'Add Test Case');
$addTestCaseButtonArea->configure(-command => [\&AddTestCase]);


# 'Feature and Test Case Lists
$featuresLabel = $main->Label(-text=>'Features');

$featuresListBox = $main->Listbox(-selectmode=>"browse", -width=>0, -height=>0);
$featuresListBox->bind('<ButtonPress-1>', [\&featureSelected]);

$exhibitedByLabel = $main->Label(-text=>'exhibited by ...');
$exhibitedByListBox = $main->Listbox(-selectmode=>"multiple", -width=>0, -height=>0);

$testCasesLeftButton = $main->Button(-text=>"<<");
$testCasesLeftButton->configure(-command => [\&addToExhibitedBy]);

#$testCasesRightButton = $main->Button(-text=>">>");

$testCasesLabel = $main->Label(-text=>'Test Cases');
$testCasesListBox = $main->Listbox(-selectmode=>"multiple", -width=>0, -height=>0);


# ------------------------
# Layout the form
# -----------------------
$menuBarArea->grid(-row=>0, -column=>0, -columnspan=>1, -sticky=>'ew');
